{
  "kind": "singleType",
  "collectionName": "globals",
  "info": {
    "singularName": "global",
    "pluralName": "globals",
    "displayName": "Global"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "siteName": {
      "type": "string",
      "required": true
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "footerLogo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "navbarLinks": {
      "type": "component",
      "component": "shared.navbar-link",
      "repeatable": true
    },
    "footerQuickLinksColumns": {
      "type": "integer",
      "default": 2,
      "min": 1,
      "max": 2
    },
    "footerText": {
      "type": "text"
    },
    "contactPhone": {
      "type": "string"
    },
    "contactEmail": {
      "type": "string"
    },
    "contactAddress": {
      "type": "string"
    },
    "footerCtaTitle": {
      "type": "string"
    },
    "footerCtaText": {
      "type": "text"
    },
    "footerCtaLabel": {
      "type": "string"
    },
    "footerCtaUrl": {
      "type": "string"
    },
    "socialLinks": {
      "type": "component",
      "component": "shared.social-link",
      "repeatable": true
    },
    "defaultSeo": {
      "type": "component",
      "component": "shared.seo",
      "repeatable": false
    }
  }
}
